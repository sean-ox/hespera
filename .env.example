# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=123456789

# Database
POSTGRES_USER=bugbounty
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bugbounty
DATABASE_URL=postgresql+asyncpg://bugbounty:changeme@postgres:5432/bugbounty

# Redis
REDIS_URL=redis://redis:6379/0

# Recon Settings
MAX_CONCURRENT_RECON=2
RECON_TIMEOUT_SECONDS=1800
SCHEDULE_INTERVAL_MINUTES=360
SCOPE_FILE=/app/scope.txt

# Tool Paths (inside container)
SUBFINDER_BIN=/usr/local/bin/subfinder
ASSETFINDER_BIN=/usr/local/bin/assetfinder
HTTPX_BIN=/usr/local/bin/httpx
GAU_BIN=/usr/local/bin/gau
WAYBACKURLS_BIN=/usr/local/bin/waybackurls
KATANA_BIN=/usr/local/bin/katana
NUCLEI_BIN=/usr/local/bin/nuclei

# Logging
LOG_LEVEL=INFO
JSON_LOGS=true

# Health check
HEALTH_CHECK_INTERVAL=60

# New tools paths
URO_BIN=uro
UNFURL_BIN=unfurl
QSREPLACE_BIN=qsreplace
DALFOX_BIN=dalfox
SUBZY_BIN=subzy
JSLUICE_BIN=jsluice
TRUFFLEHOG_BIN=trufflehog